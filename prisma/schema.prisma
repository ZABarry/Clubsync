generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PARENT
  REVIEWER
  MASTER_ADMIN
}

enum ClubStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum ClubPromotionStatus {
  OFFICIAL
  LOCAL
  PENDING
  DENIED
}

enum NotificationType {
  CLUB_SUBMITTED
  CLUB_APPROVED
  CLUB_DENIED
}

enum Region {
  SOUTH_WEST_LONDON
}

enum PlannedClubStatus {
  SUGGESTED
  INTERESTED
  FAVOURITE
  PLANNED
  BOOKED
  PAID
  CANCELLED
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
}

enum SharedClubParticipantStatus {
  INTERESTED
  PLANNED
  BOOKED
  PAID
  CANCELLED
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  role            UserRole  @default(PARENT)
  lastLoginAt     DateTime?
  roleUpdatedAt   DateTime?
  roleUpdatedById String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  parentProfile   ParentProfile?
  notifications   Notification[]
  roleUpdatedBy   User?         @relation("RoleUpdates", fields: [roleUpdatedById], references: [id], onDelete: SetNull)
  rolesUpdated    User[]        @relation("RoleUpdates")
  clubsReviewed   Club[]        @relation("ClubReviewedBy")
}

model ParentProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  displayName           String
  firstName             String?
  lastName              String?
  homePostcode          String?
  latitude              Float?
  longitude             Float?
  defaultSearchRadiusKm Float    @default(10)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                   User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  children               ChildProfile[]
  plannedClubs           PlannedClub[]
  sentConnections        TrustedParentConnection[] @relation("Requester")
  receivedConnections    TrustedParentConnection[] @relation("Recipient")
  sharedClubsCreated     SharedClub[]
  sharedClubParticipants SharedClubParticipant[]
  ratings                Rating[]
  clubChangeRequests     ClubChangeRequest[]
  ownedClubs             Club[]                    @relation("ClubOwner")
}

model ChildProfile {
  id                String    @id @default(uuid())
  parentProfileId   String
  nickname          String
  age               Int
  schoolYear        String?
  interests         String[]
  availabilityStart DateTime?
  availabilityEnd   DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  parent                 ParentProfile           @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  plannedClubs           PlannedClub[]
  sharedClubParticipants SharedClubParticipant[]
}

model Provider {
  id           String   @id @default(uuid())
  slug         String?  @unique
  name         String
  description  String?
  website      String?
  contactEmail String?
  phone        String?
  logoUrl      String?
  sourceUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clubs Club[]
}

model Club {
  id                   String              @id @default(uuid())
  providerId           String
  ownerParentProfileId String?
  name                 String
  description          String?
  locationName         String
  address              String?
  latitude             Float
  longitude            Float
  activities           String[]
  ageMin               Int
  ageMax               Int
  startDate            DateTime?
  endDate              DateTime?
  dailyStartTime       String?
  dailyEndTime         String?
  price                Float?
  dailyRate            Float?
  priceNote            String?
  bookingUrl           String?
  imageUrl             String?
  sourceUrl            String?
  dataConfidence       String?
  ratingAverage        Float               @default(0)
  ratingCount          Int                 @default(0)
  status               ClubStatus          @default(ACTIVE)
  promotionStatus      ClubPromotionStatus @default(OFFICIAL)
  submissionNote       String?
  reviewNote           String?
  reviewedAt           DateTime?
  reviewedByUserId     String?
  region               Region              @default(SOUTH_WEST_LONDON)
  isIndoor             Boolean             @default(false)
  isOutdoor            Boolean             @default(true)
  sendFriendly         Boolean             @default(false)
  accessibilityNotes   String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  provider       Provider            @relation(fields: [providerId], references: [id], onDelete: Cascade)
  owner          ParentProfile?      @relation("ClubOwner", fields: [ownerParentProfileId], references: [id], onDelete: SetNull)
  reviewedBy     User?               @relation("ClubReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  plannedClubs   PlannedClub[]
  sharedClubs    SharedClub[]
  ratings        Rating[]
  changeRequests ClubChangeRequest[]

  @@unique([providerId, name, locationName])
  @@index([latitude, longitude])
  @@index([startDate, endDate])
  @@index([providerId])
  @@index([ownerParentProfileId])
  @@index([promotionStatus])
}

model PlannedClub {
  id                 String            @id @default(uuid())
  parentProfileId    String
  childProfileId     String?
  clubId             String
  status             PlannedClubStatus @default(INTERESTED)
  notes              String?
  bookedDates        String[]          @default([])
  dailyRateOverride  Float?
  totalPriceOverride Float?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  parent                 ParentProfile           @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  child                  ChildProfile?           @relation(fields: [childProfileId], references: [id], onDelete: SetNull)
  club                   Club                    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  sharedClubParticipants SharedClubParticipant[]

  @@unique([parentProfileId, clubId, childProfileId])
  @@index([clubId])
  @@index([parentProfileId])
}

model TrustedParentConnection {
  id                String           @id @default(uuid())
  requesterParentId String
  recipientParentId String?
  status            ConnectionStatus @default(PENDING)
  inviteToken       String           @unique
  createdAt         DateTime         @default(now())
  acceptedAt        DateTime?

  requester ParentProfile  @relation("Requester", fields: [requesterParentId], references: [id], onDelete: Cascade)
  recipient ParentProfile? @relation("Recipient", fields: [recipientParentId], references: [id], onDelete: SetNull)

  @@index([requesterParentId])
  @@index([recipientParentId])
}

model SharedClub {
  id                String   @id @default(uuid())
  clubId            String
  createdByParentId String
  title             String
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  club         Club                    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdBy    ParentProfile           @relation(fields: [createdByParentId], references: [id], onDelete: Cascade)
  participants SharedClubParticipant[]
}

model SharedClubParticipant {
  id              String                      @id @default(uuid())
  sharedClubId    String
  parentProfileId String
  childProfileId  String?
  plannedClubId   String?
  status          SharedClubParticipantStatus @default(INTERESTED)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  sharedClub  SharedClub    @relation(fields: [sharedClubId], references: [id], onDelete: Cascade)
  parent      ParentProfile @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  child       ChildProfile? @relation(fields: [childProfileId], references: [id], onDelete: SetNull)
  plannedClub PlannedClub?  @relation(fields: [plannedClubId], references: [id], onDelete: SetNull)
}

model Rating {
  id               String           @id @default(uuid())
  clubId           String
  parentProfileId  String
  rating           Int
  reviewText       String?
  moderationStatus ModerationStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  club   Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  parent ParentProfile @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)

  @@unique([clubId, parentProfileId])
  @@index([clubId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model ClubChangeRequest {
  id                  String           @id @default(uuid())
  clubId              String
  submittedByParentId String
  fieldName           String
  suggestedValue      String
  notes               String?
  moderationStatus    ModerationStatus @default(PENDING)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  club        Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  submittedBy ParentProfile @relation(fields: [submittedByParentId], references: [id], onDelete: Cascade)
}
